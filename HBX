            sys.exit()
        except AttributeError:
            print(f"\n{RED}  ❌ ত্রুটি: HBXCOOKIESUSER ফাইলের ভেতর bot অবজেক্ট পাওয়া যায়নি।")
            sys.exit()
        except Exception as e:
            print(f"\n{RED}  ❌ এরর: {e}{RESET}")
            sys.exit()
            
    else:
        # ৩২-বিট ইউজারদের জন্য প্রফেশনাল ডিজাইন
