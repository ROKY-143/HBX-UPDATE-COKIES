import os
import platform
import sys
import time

# কালার কোড (প্রিমিয়াম লুকের জন্য)
RED   = "\033[1;31m"
GREEN = "\033[1;32m"
CYAN  = "\033[1;36m"
WHITE = "\033[1;37m"
YELLOW = "\033[1;33m"
RESET = "\033[0m"

def get_arch():
    """ডিভাইস আর্কিটেকচার চেক করা"""
    machine = platform.machine().lower()
    if "aarch64" in machine or "arm64" in machine:
        return "64"
    return "32"

def main():
    # স্ক্রিন ক্লিয়ার করা
    os.system('clear' if os.name == 'posix' else 'cls')
    
    arch_type = get_arch()

    if arch_type == "64":
        try:
            # HBXCOOKIESUSER.so ইমপোর্ট করা হচ্ছে
            import HBXCOOKIESUSER
            
            # আপনার মেইন স্ক্রিপ্টের লোগো ফাংশন কল
            HBXCOOKIESUSER.professional_logo()
            
            print(f"  │ {GREEN}[+] {WHITE}সিস্টেম চেক    : {GREEN}পাসড (64-BIT)")
            print(f"  │ {GREEN}[+] {WHITE}বট স্ট্যাটাস    : {GREEN}লোডিং হচ্ছে...")
            print(f"  └────────────────────────────────────────────────────────")
            time.sleep(1.5)
            
            print(f"\n{GREEN}  [✅] HBX COOKIES BOT IS NOW ACTIVE!{RESET}")
            print(f"{CYAN}  [!] পোলিং শুরু হচ্ছে...{RESET}\n")

            # আপনার দেওয়া সেই ইনফিনিটি পোলিং লজিক
            while True:
                try:
                    # HBXCOOKIESUSER এর ভেতরে থাকা 'bot' অবজেক্ট দিয়ে পোলিং শুরু
