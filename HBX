                    print(f"{RED}[!] পোলিং এরর: {e}{RESET}")
                    time.sleep(5)
                    
        except ImportError as e:
            print(f"\n{RED}  ❌ ত্রুটি: HBXCOOKIESUSER.so ফাইলটি পাওয়া যায়নি!")
